      "item": [
        {
          "name": "Login with correct data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json()\r",
                  "pm.collectionVariables.set(\"token\", res.token);\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.test(\"Token is present in a response\", function (){\r",
                  "    pm.expect(res).to.have.property(\"token\")\r",
                  "});\r",
                  "pm.test(\"Token is a string\", function () {\r",
                  "    pm.expect(res.token).to.be.a(\"string\")\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableCookies": true
          },
